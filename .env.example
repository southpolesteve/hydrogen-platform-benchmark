# Server environment. Copy to `.env` and fill in.
#
# Mode is auto-detected: with a PRIVATE_STOREFRONT_API_TOKEN present the app uses
# private server-side access. Without one, it uses the real public Hydrogen Demo
# Store with its published public token. Set MOCK_SHOP=1 to force mock.shop explicitly.

# Force the synthetic mock.shop backend instead of a real Shopify store.
# MOCK_SHOP=1

# Public store. Defaults to hydrogen-preview.myshopify.com and its published token.
PUBLIC_STORE_DOMAIN=
PUBLIC_STOREFRONT_API_TOKEN=

# Private real store access (server-only). When set, private mode takes precedence.
PRIVATE_STOREFRONT_API_TOKEN=

# Analytics identity (optional). The Hydrogen sales channel populates these for a
# linked store; pull them with `shopify hydrogen env pull`. When unset, analytics
# falls back to the public Hydrogen Preview store so a fresh deploy still renders.
# SHOP_ID is the numeric shop id (a gid:// value is also accepted).
SHOP_ID=
PUBLIC_STOREFRONT_ID=
