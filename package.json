{
  "name": "hydrogen-platform-benchmark",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && gql.tada check",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "wrangler dev --config dist/server/wrangler.json",
    "deploy:vinext": "vinext-cloudflare deploy --config dist/server/wrangler.json",
    "benchmark": "node benchmarks/platform.mjs"
  },
  "dependencies": {
    "@shopify/hydrogen": "preview",
    "@vinext/cloudflare": "1.0.0-beta.3",
    "next": "16.2.7",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-server-dom-webpack": "^19.2.8",
    "vinext": "1.0.0-beta.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitejs/plugin-rsc": "^0.5.29",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "gql.tada": "1.9.2",
    "graphql": "^16.13.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0"
  },
  "type": "module"
}
